generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                                    String                 @id @default(cuid())
  username                                              String                 @unique
  email                                                 String                 @unique
  password                                              String
  name                                                  String
  phone                                                 String?
  address                                               String?
  dateOfBirth                                           DateTime?
  placeOfBirth                                          String?
  nip                                                   String?                @unique
  employeeStatus                                        String                 @default("PKWT")
  joinDate                                              DateTime?
  roleId                                                String
  divisionId                                            String
  accessLevel                                           Int                    @default(5)
  companyType                                           String                 @default("subsidiary")
  supervisorId                                          String?
  bpjsHealth                                            String?
  bpjsEmployment                                        String?
  overtimeRate                                          Decimal                @default(0) @db.Decimal(10, 2)
  createdAt                                             DateTime               @default(now())
  updatedAt                                             DateTime               @updatedAt
  contractEndDate                                       DateTime?
  contractStartDate                                     DateTime?
  gender                                                String?                @default("Male")
  lastPasswordChange                                    DateTime?
  plottingCompanyId                                     String?
  nik                                                   String?                @unique
  npwp                                                  String?                @unique
  scopeEntityIds                                        String[]               @default([])
  scopeGroupIds                                         String[]               @default([])
  adjustmentsMade                                       BalanceAdjustmentLog[] @relation("AdjustedBy")
  balanceAdjustments                                    BalanceAdjustmentLog[]
  EmployeeDocument_EmployeeDocument_uploadedByIdTousers EmployeeDocument[]     @relation("EmployeeDocument_uploadedByIdTousers")
  EmployeeDocument_EmployeeDocument_userIdTousers       EmployeeDocument[]     @relation("EmployeeDocument_userIdTousers")
  emergencyContacts                                     EmergencyContact[]
  announcements                                         Announcement[]
  leaveBalances                                         LeaveBalance[]
  leaveApprovals                                        LeaveRequest[]         @relation("LeaveCurrentApprover")
  divisionHeadLeaves                                    LeaveRequest[]         @relation("LeaveDivisionHead")
  leaveRequests                                         LeaveRequest[]
  supervisorLeaves                                      LeaveRequest[]         @relation("LeaveSupervisor")
  offboardingsCreated                                   Offboarding[]          @relation("OffboardingCreator")
  offboarding                                           Offboarding?           @relation("OffboardingEmployee")
  offboardingsHRD                                       Offboarding[]          @relation("OffboardingHRD")
  offboardingsSupervisor                                Offboarding[]          @relation("OffboardingSupervisor")
  overtimeBalance                                       OvertimeBalance?
  overtimeRecaps                                        OvertimeRecap[]
  originalRecaps                                        OvertimeRecap[]        @relation("OriginalRecapper")
  recapsMade                                            OvertimeRecap[]        @relation("RecappedBy")
  overtimeApprovals                                     OvertimeRequest[]      @relation("CurrentApprover")
  divisionHeadOvertimes                                 OvertimeRequest[]      @relation("OvertimeDivisionHead")
  overtimeRequests                                      OvertimeRequest[]
  finalApprovals                                        OvertimeRequest[]      @relation("FinalApprover")
  supervisorOvertimes                                   OvertimeRequest[]      @relation("OvertimeSupervisor")
  overtimeRevisions                                     OvertimeRevision[]
  PasswordReset                                         PasswordReset[]
  payslips                                              Payslip[]
  uploadedPayslips                                      Payslip[]              @relation("UploadedPayslips")
  recapDateAdjustments                                  RecapDateAdjustment[]  @relation("RecapDateAdjustedBy")
  systemSettingsRecapped                                SystemSettings[]       @relation("SystemSettingsRecappedBy")
  toilEntries                                           TimeOffInLieu[]
  entityGroupAudits                                     EntityGroupAudit[]
  managedGroups                                         EntityGroup[]          @relation("GroupManager")
  division                                              Division               @relation(fields: [divisionId], references: [id])
  plottingCompany                                       PlottingCompany?       @relation(fields: [plottingCompanyId], references: [id])
  role                                                  Role                   @relation(fields: [roleId], references: [id])
  supervisor                                            User?                  @relation("Supervision", fields: [supervisorId], references: [id], onUpdate: NoAction)
  subordinates                                          User[]                 @relation("Supervision")
  step1ApprovedLeaves                                   LeaveRequest[]         @relation("LeaveStep1Approver")
  workStatuses                                          WorkStatus[]           @relation("WorkStatusEmployee")
  workStatusesSubmitted                                 WorkStatus[]           @relation("WorkStatusSubmitter")
  workStatusDefault                                     WorkStatusDefault?     @relation("WorkStatusDefault")
  workStatusDefaultsSet                                 WorkStatusDefault[]    @relation("WorkStatusDefaultSetter")
  attendanceViewPermissions                             AttendanceViewPermission[] @relation("AttendanceViewPermissions")
  attendancePermissionsGranted                          AttendanceViewPermission[] @relation("AttendancePermissionsGranted")
  jobPostingsCreated                                    JobPosting[]               @relation("JobPostingCreator")
  recruitingPositions                                   JobPosting[]               @relation("JobPostingRecruiter")
  positionOverseers                                     PositionOverseer[]
  wfhQuota                                              WfhQuota?                  @relation("WfhQuota")
  wfhQuotasSet                                          WfhQuota[]                 @relation("WfhQuotaSetter")
  wfhSchedules                                          WfhSchedule[]              @relation("WfhScheduleEmployee")
  wfhScheduleOverrides                                  WfhSchedule[]              @relation("WfhScheduleOverrider")
  wfhWindowOverridesOpened                              WfhWindowOverride[]        @relation("WfhWindowOverrideOpener")
  wfhExclusion                                          WfhExcludedEmployee?       @relation("WfhExcluded")
  wfhExclusionsSet                                      WfhExcludedEmployee[]      @relation("WfhExcluder")

  @@index([email])
  @@index([username])
  @@index([supervisorId])
  @@index([roleId])
  @@index([divisionId])
  @@index([accessLevel])
  @@index([email], map: "idx_users_email")
  @@index([nip], map: "idx_users_nip")
  @@index([nik], map: "idx_users_nik")
  @@index([npwp], map: "idx_users_npwp")
  @@index([scopeEntityIds], map: "idx_users_scopeEntityIds", type: Gin)
  @@index([scopeGroupIds], type: Gin)
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  users       User[]
}

model Division {
  id          String   @id @default(cuid())
  name        String
  headId      String?
  createdAt   DateTime @default(now())
  description String?
  users       User[]

  @@map("Division")
}

model PlottingCompany {
  id          String             @id @default(cuid())
  name        String             @unique
  code        String?            @unique
  description String?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  groupId     String?
  payslips    Payslip[]
  group       EntityGroup?       @relation(fields: [groupId], references: [id])
  auditLogs   EntityGroupAudit[]
  users       User[]
  policyAssignments  PolicyAssignment[]  @relation("EntityPolicyAssignments")
  subgroupId  String?
  subgroup    EntitySubgroup?  @relation(fields: [subgroupId], references: [id])
  jobPostings JobPosting[]

  @@map("PlottingCompany")
}

model EntityGroup {
  id          String             @id @default(cuid())
  name        String             @unique
  code        String?            @unique
  description String?
  color       String?            @default("#3B82F6")
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  managerId   String?
  companies   PlottingCompany[]
  auditLogs   EntityGroupAudit[]
  manager     User?              @relation("GroupManager", fields: [managerId], references: [id])
  policyAssignments  PolicyAssignment[]  @relation("GroupPolicyAssignments")
  subgroups  EntitySubgroup[]

  @@map("entity_groups")
}

model EntityGroupAudit {
  id          String           @id @default(cuid())
  action      String
  entityId    String?
  groupId     String?
  oldGroupId  String?
  newGroupId  String?
  changes     Json?
  performedBy String
  createdAt   DateTime         @default(now())
  entity      PlottingCompany? @relation(fields: [entityId], references: [id])
  group       EntityGroup?     @relation(fields: [groupId], references: [id])
  user        User             @relation(fields: [performedBy], references: [id])

  @@index([entityId])
  @@index([groupId])
  @@index([createdAt])
  @@map("entity_group_audit")
}

model EntitySubgroup {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String?  @unique
  description String?
  color       String?  @default("#6366F1")
  isActive    Boolean  @default(true)

  groupId     String
  group       EntityGroup       @relation(fields: [groupId], references: [id])
  companies   PlottingCompany[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([groupId])
  @@map("entity_subgroups")
}

// ─── PolicyTemplate ───────────────────────────────────────────────────────────
// Defines a named set of business rules.
// Has NO direct scope — scope is defined by PolicyAssignment rows.
// One template can be assigned to many entities/groups.

model PolicyTemplate {
  id    String  @id @default(cuid())
  name  String                         // e.g. "KGI Standard", "Rhaya Flicks Policy"
  description String?

  // ── Overtime ─────────────────────────────────────────────────────────────
  // "pre"  = submit plan BEFORE overtime (KGI)
  // "post" = submit AFTER within window  (Rhaya)
  overtimeMode                  String  @default("post")
  overtimeSubmissionWindowDays  Int     @default(7)
  overtimeAllowLateSubmission   Boolean @default(false)

  // ── Leave ─────────────────────────────────────────────────────────────────
  // 1 = single step, 2 = two-step
  leaveApprovalSteps    Int    @default(1)
  leaveStep1Approvers   String @default("supervisor,dept_head,hr")
  leaveStep2Approvers   String @default("hr")

  // ── Pay rates ─────────────────────────────────────────────────────────────
  overtimeRateWeekday   Float @default(1.5)
  overtimeRateWeekend   Float @default(2.0)
  overtimeRateHoliday   Float @default(3.0)

  // ── Attendance ────────────────────────────────────────────────────────────
  lateToleranceMinutes  Int   @default(15)

  // ── Internal policy document ──────────────────────────────────────────────
  internalPolicyUrl     String?

  // ── HR contact & SMTP profile ─────────────────────────────────────────────
  // hrEmail: designated HR email for notifications tied to this policy
  hrEmail      String?
  // smtpProfile: key that maps to env var group SMTP2GO_{KEY}_USER / PASS / FROM_EMAIL / FROM_NAME
  //   e.g. "kgi"  → SMTP2GO_KGI_USER, SMTP2GO_KGI_PASS, SMTP2GO_KGI_FROM_EMAIL, SMTP2GO_KGI_FROM_NAME
  //   null / "default" → falls back to SMTP2GO_USER / SMTP2GO_PASS / etc.
  smtpProfile  String?

  // ── Metadata ──────────────────────────────────────────────────────────────
  isActive  Boolean  @default(true)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments PolicyAssignment[]

  @@map("policy_templates")
}

// ─── PolicyAssignment ─────────────────────────────────────────────────────────
// Links a PolicyTemplate to a target (entity OR group).
// Priority controls conflict resolution when multiple assignments match.
// HIGHER number = higher priority (wins).
//
// Example:
//   KGI group assigned template "KGI Standard"      priority 10
//   Entity A  assigned template "Entity A Override"  priority 20  ← wins for Entity A
//
// Conflict resolution in policyResolver:
//   1. Collect all assignments that apply to the entity (direct + via group)
//   2. Sort by priority DESC
//   3. Take highest priority — that template's rules win entirely
//      (no field-level merging between templates; one template wins)

model PolicyAssignment {
  id          String  @id @default(cuid())

  templateId  String
  template    PolicyTemplate @relation(fields: [templateId], references: [id])

  // Target — exactly one of these is set
  entityId      String?
  entityGroupId String?

  // Higher = wins when multiple assignments match the same entity
  priority    Int     @default(10)

  // Optional label override for this specific assignment
  label       String?

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entity       PlottingCompany? @relation("EntityPolicyAssignments", fields: [entityId],      references: [id])
  entityGroup  EntityGroup?     @relation("GroupPolicyAssignments",  fields: [entityGroupId], references: [id])

  // Prevent duplicate assignments of same template to same target
  @@unique([templateId, entityId])
  @@unique([templateId, entityGroupId])

  @@map("policy_assignments")
}

model LeaveBalance {
  id                 String   @id @default(cuid())
  employeeId         String
  annualQuota        Int      @default(0)
  annualUsed         Int      @default(0)
  annualRemaining    Int      @default(0)
  sickLeaveUsed      Int      @default(0)
  menstrualLeaveUsed Int      @default(0)
  unpaidLeaveUsed    Int      @default(0)
  year               Int
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
  toilBalance        Int      @default(0)
  toilExpired        Int      @default(0)
  toilUsed           Int      @default(0)
  employee           User     @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, year])
  @@map("LeaveBalance")
}

model LeaveRequest {
  id                  String         @id @default(cuid())
  leaveType           String
  startDate           DateTime
  endDate             DateTime
  reason              String
  status              String         @default("PENDING")
  approvedAt          DateTime?
  rejectedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  attachment          String?
  currentApproverId   String?
  divisionHeadComment String?
  divisionHeadDate    DateTime?
  divisionHeadId      String?
  divisionHeadStatus  String?
  employeeId          String
  isPaid              Boolean        @default(true)
  supervisorComment   String?
  supervisorDate      DateTime?
  supervisorId        String?
  supervisorStatus    String?
  totalDays           Float
  isToil              Boolean        @default(false)
  cancellationReason  String?
  cancelledAt         DateTime?
  currentApprover     User?          @relation("LeaveCurrentApprover", fields: [currentApproverId], references: [id])
  divisionHead        User?          @relation("LeaveDivisionHead", fields: [divisionHeadId], references: [id])
  employee            User           @relation(fields: [employeeId], references: [id])
  supervisor          User?          @relation("LeaveSupervisor", fields: [supervisorId], references: [id])
  toilEntry           TimeOffInLieu?

  step1ApprovedById  String?
  step1ApprovedAt    DateTime?
  step1ApprovedBy    User?  @relation("LeaveStep1Approver", fields: [step1ApprovedById], references: [id])

  @@map("LeaveRequest")
}

model OvertimeRequest {
  id                  String             @id @default(cuid())
  employeeId          String
  submittedAt         DateTime           @default(now())
  status              String             @default("PENDING")
  currentApproverId   String?
  supervisorId        String?
  supervisorStatus    String             @default("PENDING")
  supervisorComment   String?
  supervisorDate      DateTime?
  divisionHeadId      String?
  divisionHeadStatus  String             @default("PENDING")
  divisionHeadComment String?
  divisionHeadDate    DateTime?
  totalHours          Float
  totalAmount         Float
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  approvedAt          DateTime?
  rejectedAt          DateTime?
  finalApproverId     String?
  recapId             String?
  isRecapped          Boolean            @default(false)
  recappedDate        DateTime?
  entries             OvertimeEntry[]
  currentApprover     User?              @relation("CurrentApprover", fields: [currentApproverId], references: [id])
  divisionHead        User?              @relation("OvertimeDivisionHead", fields: [divisionHeadId], references: [id])
  employee            User               @relation(fields: [employeeId], references: [id])
  finalApprover       User?              @relation("FinalApprover", fields: [finalApproverId], references: [id])
  recap               OvertimeRecap?     @relation(fields: [recapId], references: [id])
  supervisor          User?              @relation("OvertimeSupervisor", fields: [supervisorId], references: [id])
  revisions           OvertimeRevision[]
  overtimeMode        String   @default("post")
  isIncidental        Boolean  @default(false)
  incidentalReason    String?

  @@index([employeeId])
  @@index([status])
  @@index([currentApproverId])
  @@index([isRecapped])
}

model OvertimeEntry {
  id                String          @id @default(cuid())
  overtimeRequestId String
  date              DateTime
  hours             Float
  plannedHours      Float?     // original estimate in pre-flow plan
  actualHours       Float?     // filled during actualization step
  actualizedAt      DateTime?  // when employee actualized this entry
  description       String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  overtimeRequest   OvertimeRequest @relation(fields: [overtimeRequestId], references: [id], onDelete: Cascade)

  @@index([overtimeRequestId])
  @@index([date])
}

model OvertimeBalance {
  id              String    @id @default(cuid())
  employeeId      String    @unique
  currentBalance  Float     @default(0)
  pendingHours    Float     @default(0)
  totalPaid       Float     @default(0)
  lastProcessedAt DateTime?
  lastResetAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  employee        User      @relation(fields: [employeeId], references: [id])
}

model OvertimeRevision {
  id                String          @id @default(cuid())
  overtimeRequestId String
  revisedBy         String
  action            String
  changes           Json
  comment           String?
  createdAt         DateTime        @default(now())
  overtimeRequest   OvertimeRequest @relation(fields: [overtimeRequestId], references: [id], onDelete: Cascade)
  reviser           User            @relation(fields: [revisedBy], references: [id])

  @@index([overtimeRequestId])
}

model OvertimeRecap {
  id                 String            @id @default(cuid())
  employeeId         String
  month              Int
  year               Int
  totalHours         Float
  paidHours          Float
  excessHours        Float
  carryoverHours     Float             @default(0)
  totalToilHours     Float
  toilDaysCreated    Int               @default(0)
  remainingHours     Float             @default(0)
  recappedById       String
  recappedAt         DateTime          @default(now())
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  fromDate           DateTime
  toDate             DateTime
  recapStatus        String            @default("success")
  failureReason      String?
  lastLateAdditionAt DateTime?
  lateAdditionCount  Int               @default(0)
  lateAdditionHours  Float             @default(0)
  originalPaidHours  Float?
  originalRecappedAt DateTime?
  originalRecappedBy String?
  originalTotalHours Float?
  employee           User              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  originalRecapper   User?             @relation("OriginalRecapper", fields: [originalRecappedBy], references: [id])
  recappedBy         User              @relation("RecappedBy", fields: [recappedById], references: [id])
  overtimeRequests   OvertimeRequest[]
  toilEntries        TimeOffInLieu[]

  @@unique([employeeId, year, month])
  @@index([employeeId])
  @@index([year, month])
  @@index([recapStatus])
  @@map("OvertimeRecap")
}

model TimeOffInLieu {
  id             String         @id @default(cuid())
  employeeId     String
  days           Int
  hoursSource    Float
  earnedMonth    Int
  earnedYear     Int
  expiryMonth    Int
  expiryYear     Int
  status         String         @default("available")
  usedDate       DateTime?
  expiredDate    DateTime?
  recapId        String?
  leaveRequestId String?        @unique
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  employee       User           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveRequest   LeaveRequest?  @relation(fields: [leaveRequestId], references: [id])
  recap          OvertimeRecap? @relation(fields: [recapId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([earnedYear, earnedMonth])
  @@index([expiryYear, expiryMonth])
  @@map("TimeOffInLieu")
}

model Payslip {
  id                String          @id @default(cuid())
  grossSalary       Float?
  netSalary         Float?
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  employeeId        String
  fileName          String
  fileSize          Int
  fileUrl           String
  month             Int
  uploadedAt        DateTime        @default(now())
  uploadedById      String
  viewCount         Int             @default(0)
  viewedAt          DateTime?
  year              Int
  plottingCompanyId String          @default("cmlhwaz25001l12jd2i6muasr")
  employee          User            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  plottingCompany   PlottingCompany @relation(fields: [plottingCompanyId], references: [id])
  uploadedBy        User            @relation("UploadedPayslips", fields: [uploadedById], references: [id])

  @@unique([employeeId, year, month, plottingCompanyId])
  @@index([employeeId])
  @@index([year, month])
  @@map("Payslip")
}

model PasswordResetToken {
  id               String    @id @default(cuid())
  userId           String
  token            String    @unique
  tempPasswordHash String
  expiresAt        DateTime
  usedAt           DateTime?
  createdAt        DateTime  @default(now())

  @@index([token])
  @@index([expiresAt])
}

model BalanceAdjustmentLog {
  id              String   @id @default(cuid())
  userId          String
  adjustedBy      String
  type            String
  amount          Float
  previousBalance Float
  newBalance      Float
  reason          String
  year            Int?
  createdAt       DateTime @default(now())
  adjuster        User     @relation("AdjustedBy", fields: [adjustedBy], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@map("BalanceAdjustmentLog")
}

model SystemSettings {
  id                   String    @id @default(cuid())
  lastRecapDate        DateTime?
  lastRecapMonth       Int?
  lastRecapYear        Int?
  isRecapInProgress    Boolean   @default(false)
  isApprovalLocked     Boolean   @default(false)
  lastRecapCompletedAt DateTime?
  lastRecapBy          String?
  updatedAt            DateTime  @updatedAt
  createdAt            DateTime  @default(now())
  lastRecapByUser      User?     @relation("SystemSettingsRecappedBy", fields: [lastRecapBy], references: [id])

  @@map("SystemSettings")
}

model RecapDateAdjustment {
  id         String   @id @default(cuid())
  oldDate    DateTime
  newDate    DateTime
  reason     String
  adjustedBy String
  createdAt  DateTime @default(now())
  adjuster   User     @relation("RecapDateAdjustedBy", fields: [adjustedBy], references: [id])

  @@index([createdAt(sort: Desc)])
  @@map("RecapDateAdjustment")
}

model PasswordReset {
  id        String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  token     String    @unique
  expiresAt DateTime
  used      Boolean   @default(false)
  usedAt    DateTime?
  ipAddress String?
  createdAt DateTime  @default(now())
  users     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([token])
  @@index([userId])
}

model EmployeeDocument {
  id                                         String    @id @default(cuid())
  userId                                     String
  fileName                                   String
  fileUrl                                    String
  fileSize                                   Int
  mimeType                                   String    @default("application/pdf")
  documentType                               String
  documentNumber                             String?
  startDate                                  DateTime?
  endDate                                    DateTime?
  status                                     String    @default("active")
  notes                                      String?
  uploadedById                               String
  uploadedAt                                 DateTime  @default(now())
  users_EmployeeDocument_uploadedByIdTousers User      @relation("EmployeeDocument_uploadedByIdTousers", fields: [uploadedById], references: [id], map: "ContractFile_uploadedById_fkey")
  users_EmployeeDocument_userIdTousers       User      @relation("EmployeeDocument_userIdTousers", fields: [userId], references: [id], onDelete: Cascade, map: "ContractFile_userId_fkey")

  @@index([documentType])
  @@index([status])
  @@index([userId])
}

model EmergencyContact {
  id           String   @id @default(cuid())
  userId       String
  name         String
  relationship String
  phone        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("emergency_contacts")
}

model Announcement {
  id                 String    @id @default(cuid())
  title              String
  body               String
  isPinned           Boolean   @default(false)
  expiresAt          DateTime?
  // Empty array on any of these = no restriction on that dimension.
  // A user sees the announcement only if they match every non-empty dimension.
  targetAccessLevels Int[]     @default([])
  targetEntityIds    String[]  @default([])
  targetGroupIds     String[]  @default([])
  targetSubgroupIds  String[]  @default([])
  targetDivisionIds  String[]  @default([])
  createdById        String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  createdBy          User      @relation(fields: [createdById], references: [id])

  @@index([createdById])
  @@index([expiresAt])
  @@index([isPinned])
  @@map("announcements")
}

model Offboarding {
  id                   String    @id @default(cuid())
  employeeId           String    @unique
  offboardingType      String
  resignDate           DateTime?
  lastWorkingDay       DateTime
  resignReason         String?
  reasonDetails        String?
  handoverCompleted    Boolean   @default(false)
  handoverNotes        String?
  documentationDone    Boolean   @default(false)
  documentationNotes   String?
  accessTransferred    Boolean   @default(false)
  accessNotes          String?
  laptopReturned       Boolean   @default(false)
  laptopNotes          String?
  idCardReturned       Boolean   @default(false)
  idCardNotes          String?
  emailRevoked         Boolean   @default(false)
  emailNotes           String?
  otherAssetReturned   Boolean   @default(false)
  otherAssetNotes      String?
  loanSettled          Boolean   @default(false)
  loanNotes            String?
  reimbursementClaimed Boolean   @default(false)
  reimbursementNotes   String?
  finalPayrollDone     Boolean   @default(false)
  finalPayrollNotes    String?
  exitInterviewDone    Boolean   @default(false)
  exitInterviewLink    String?
  exitInterviewNotes   String?
  employeeAcknowledged Boolean   @default(false)
  employeeSignedAt     DateTime?
  supervisorApproved   Boolean   @default(false)
  supervisorSignedAt   DateTime?
  supervisorId         String?
  hrdApproved          Boolean   @default(false)
  hrdSignedAt          DateTime?
  hrdId                String?
  status               String    @default("IN_PROGRESS")
  completedAt          DateTime?
  createdBy            String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  creator              User      @relation("OffboardingCreator", fields: [createdBy], references: [id])
  employee             User      @relation("OffboardingEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  hrd                  User?     @relation("OffboardingHRD", fields: [hrdId], references: [id])
  supervisor           User?     @relation("OffboardingSupervisor", fields: [supervisorId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([lastWorkingDay])
  @@map("Offboarding")
}

// ─── Work Status ──────────────────────────────────────────────────────────────
// Tracks daily work location / attendance status per employee.
// No row = WFO (default). LEAVE rows auto-created from approved leave requests.
// Past dates are read-only; today + future are editable.

model WorkStatus {
  id          String   @id @default(cuid())
  employeeId  String
  date        DateTime @db.Date
  status      String   @default("WFO")  // WFO | WFH | LEAVE | OUTSIDE_OFFICE
  note        String?
  submittedBy String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee    User     @relation("WorkStatusEmployee",  fields: [employeeId],  references: [id])
  submitter   User     @relation("WorkStatusSubmitter", fields: [submittedBy], references: [id])

  @@unique([employeeId, date])
  @@index([date])
  @@index([employeeId])
  @@map("work_status")
}

// ─── Attendance View Permission ───────────────────────────────────────────────
// Grants a specific account read access to work-status data for a scoped group.
// scopeType: ENTITY (PlottingCompany) | SUBGROUP (EntitySubgroup) | GROUP (EntityGroup)
// One user can hold multiple grants across different scopes.

model AttendanceViewPermission {
  id         String   @id @default(cuid())
  userId     String
  scopeType  String   // ENTITY | SUBGROUP | GROUP
  scopeId    String
  accessType String   @default("VIEW")  // VIEW | EDIT
  grantedBy  String
  createdAt  DateTime @default(now())

  user      User     @relation("AttendanceViewPermissions",    fields: [userId],    references: [id])
  granter   User     @relation("AttendancePermissionsGranted", fields: [grantedBy], references: [id])

  @@unique([userId, scopeType, scopeId])
  @@index([userId])
  @@map("attendance_view_permissions")
}

// ─── Work Status Default ───────────────────────────────────────────────────────
// Per-employee default attendance status applied to any day without an explicit record.
// Employee or admin can set; applies to today and all future dates (used as fallback).

model WorkStatusDefault {
  id         String   @id @default(cuid())
  employeeId String   @unique
  status     String   @default("WFO")  // WFO | WFH | LEAVE | OUTSIDE_OFFICE
  note       String?
  setBy      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee   User     @relation("WorkStatusDefault",       fields: [employeeId], references: [id])
  setter     User     @relation("WorkStatusDefaultSetter", fields: [setBy],      references: [id])

  @@map("work_status_defaults")
}

// ─── WFH Scheduling ───────────────────────────────────────────────────────────
// Configurable per entity/subgroup/group. Employees pick their WFH day each week
// during the Sat-Sun submission window. Division cap enforced (max 1 per division
// per day, or ceil(members/workingDays) when division is large).

model WfhFeatureScope {
  id        String   @id @default(cuid())
  scopeType String   // ENTITY | SUBGROUP | GROUP
  scopeId   String
  isActive  Boolean  @default(true)
  createdBy String
  createdAt DateTime @default(now())

  @@unique([scopeType, scopeId])
  @@map("wfh_feature_scopes")
}

model WfhQuota {
  id           String   @id @default(cuid())
  employeeId   String   @unique
  quotaPerWeek Int      @default(1)
  setBy        String
  updatedAt    DateTime @updatedAt

  employee User @relation("WfhQuota",       fields: [employeeId], references: [id])
  setter   User @relation("WfhQuotaSetter", fields: [setBy],      references: [id])

  @@map("wfh_quotas")
}

model WfhSchedule {
  id            String   @id @default(cuid())
  employeeId    String
  weekStartDate DateTime // Monday 00:00 UTC of target week
  wfhDate       DateTime // Specific WFH day (Mon-Fri, non-holiday)
  status        String   @default("PENDING") // PENDING | CONFIRMED | ADMIN_OVERRIDE
  overriddenBy  String?
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee  User  @relation("WfhScheduleEmployee",  fields: [employeeId],   references: [id])
  overrider User? @relation("WfhScheduleOverrider", fields: [overriddenBy], references: [id])

  @@unique([employeeId, wfhDate])      // one slot per calendar date per employee
  @@index([weekStartDate])
  @@index([employeeId])
  @@map("wfh_schedules")
}

// Admin can force-open the WFH submission window outside of the regular Sat-Sun schedule.
// Singleton record (id="global"). expiresAt optional — null means open until admin closes.
model WfhWindowOverride {
  id        String    @id @default("global")
  isActive  Boolean   @default(false)
  openedBy  String?
  openedAt  DateTime?
  expiresAt DateTime? // auto-close after this time; null = no expiry
  note      String?   // reason / context for the override

  opener User? @relation("WfhWindowOverrideOpener", fields: [openedBy], references: [id])

  @@map("wfh_window_overrides")
}

model WfhExcludedEmployee {
  id         String   @id @default(cuid())
  employeeId String   @unique
  excludedBy String?
  reason     String?
  createdAt  DateTime @default(now())

  employee User  @relation("WfhExcluded", fields: [employeeId], references: [id], onDelete: Cascade)
  excluder User? @relation("WfhExcluder", fields: [excludedBy], references: [id])

  @@map("wfh_excluded_employees")
}

// ─── Recruitment ───────────────────────────────────────────────────────────────
// Standalone recruitment website shares this backend + DB.
// HR = existing User auth (entity-scoped). Candidates = separate Applicant table.

model Applicant {
  id             String           @id @default(cuid())
  email          String           @unique
  password       String                            // bcrypt (cost 10), same as auth.controller
  name           String
  phone          String?
  resumeUrl      String?                           // legacy; use cvFileUrl for R2 uploads
  cvFileUrl      String?                           // R2 URL of uploaded CV file
  parsedCv       Json?                             // structured CV — shape locked in RECRUITMENT_PLAN.md
  emailVerified  Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  applications   JobApplication[]
  profileAnswers ProfileAnswer[]

  @@map("applicants")
}

model JobPosting {
  id                String           @id @default(cuid())
  title             String
  description       String                       // long text / markdown
  department        String?
  location          String?
  employmentType    String           @default("FULL_TIME") // FULL_TIME|CONTRACT|INTERN
  status            String           @default("DRAFT")     // DRAFT|OPEN|CLOSED
  openings          Int              @default(1)
  closeDate         DateTime?
  plottingCompanyId String                       // entity scope anchor
  createdById       String                       // HR User who created
  recruiterId       String?                      // assigned recruiter (HR User)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  plottingCompany   PlottingCompany      @relation(fields: [plottingCompanyId], references: [id])
  createdBy         User                 @relation("JobPostingCreator",   fields: [createdById],  references: [id])
  recruiter         User?                @relation("JobPostingRecruiter",  fields: [recruiterId],  references: [id])
  applications      JobApplication[]
  questions         PositionQuestion[]
  overseers         PositionOverseer[]
  documents         RecruitmentDocument[]

  @@index([plottingCompanyId])
  @@index([status])
  @@index([recruiterId])
  @@map("job_postings")
}

model JobApplication {
  id             String             @id @default(cuid())
  jobPostingId   String
  applicantId    String
  // 12-stage pipeline: applied→screening→case_study_1→interview→case_study_2→
  //   final_interview→col_issued→background_check→offer→hired/rejected/withdrawn
  stage          String             @default("applied")
  coverLetter    String?
  resumeUrl      String?                          // per-application CV override
  hrNotes        String?
  rejectedReason String?
  knockoutFlagged Boolean           @default(false) // soft knockout flag for HR review
  appliedAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  jobPosting     JobPosting            @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  applicant      Applicant             @relation(fields: [applicantId],  references: [id], onDelete: Cascade)
  events         ApplicationEvent[]
  answers        Answer[]
  documents      RecruitmentDocument[]

  @@unique([jobPostingId, applicantId])
  @@index([jobPostingId])
  @@index([applicantId])
  @@index([stage])
  @@map("job_applications")
}

model ApplicationEvent {                          // pipeline audit trail
  id            String         @id @default(cuid())
  applicationId String
  type          String                            // STAGE_CHANGE|NOTE|INTERVIEW_SCHEDULED|DOCUMENT_ISSUED|DOCUMENT_RECEIVED
  fromStage     String?
  toStage       String?
  note          String?
  scheduledAt   DateTime?
  actorType     String                            // HR|APPLICANT|SYSTEM
  actorId       String?
  createdAt     DateTime       @default(now())

  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_events")
}

// ─── Recruitment v2 — Question bank + answers ─────────────────────────────────

model Question {
  id           String   @id @default(cuid())
  text         String
  type         String   // bool | single | multi | number | text
  isKnockout   Boolean  @default(false)
  knockoutRule Json?    // { operator: "equals"|"min"|"max"|"includes", value, soft: bool }
  scope        String   @default("position") // position (per-application) | common (per-candidate, asked once)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  positionQuestions PositionQuestion[]
  answers           Answer[]
  profileAnswers    ProfileAnswer[]

  @@index([scope])
  @@map("questions")
}

model PositionQuestion {
  id           String     @id @default(cuid())
  jobPostingId String
  questionId   String
  order        Int        @default(0)

  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  question     Question   @relation(fields: [questionId],   references: [id], onDelete: Cascade)

  @@unique([jobPostingId, questionId])
  @@index([jobPostingId])
  @@map("position_questions")
}

model Answer {
  id            String         @id @default(cuid())
  applicationId String
  questionId    String
  value         Json

  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  question      Question       @relation(fields: [questionId],    references: [id])

  @@unique([applicationId, questionId])
  @@index([applicationId])
  @@map("answers")
}

model ProfileAnswer {
  id          String    @id @default(cuid())
  applicantId String
  questionId  String
  value       Json

  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  question    Question  @relation(fields: [questionId],  references: [id])

  @@unique([applicantId, questionId])
  @@index([applicantId])
  @@map("profile_answers")
}

// ─── Recruitment v2 — Overseers + Documents ───────────────────────────────────

model PositionOverseer {
  id           String     @id @default(cuid())
  jobPostingId String
  hrisUserId   String
  access       String     @default("view") // view | manage
  addedBy      String
  createdAt    DateTime   @default(now())

  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  hrisUser     User       @relation(fields: [hrisUserId],   references: [id])

  @@unique([jobPostingId, hrisUserId])
  @@index([jobPostingId])
  @@index([hrisUserId])
  @@map("position_overseers")
}

model RecruitmentDocument {
  id            String          @id @default(cuid())
  applicationId String?
  jobPostingId  String?
  stage         String?         // pipeline stage this doc is associated with
  direction     String          // outbound (HR→candidate) | inbound (candidate→HR)
  kind          String          // file (R2) | link (external URL)
  title         String
  fileUrl       String?
  linkUrl       String?
  uploadedBy    String?         // User.id for HR, null for candidate/system
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  application   JobApplication? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  jobPosting    JobPosting?     @relation(fields: [jobPostingId],  references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([jobPostingId])
  @@map("recruitment_documents")
}
