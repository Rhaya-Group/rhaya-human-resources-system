# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Neon Postgres — get connection string from team lead
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── JWT ───────────────────────────────────────────────────────────────────────
# Used for BOTH HR user tokens AND candidate tokens (different payloads).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Primary frontend domains (set per Railway environment)
FRONTEND_URL=http://localhost:5173
RECRUITMENT_URL=http://localhost:5176
# Extra origins for staging/preview (comma-separated, no spaces)
# e.g. ALLOWED_ORIGINS=https://staging.example.com,https://preview.example.com
ALLOWED_ORIGINS=

# ── Cloudflare R2 (file storage — CV uploads + stage documents) ───────────────
# Create API token in Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-bucket-name
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
# Public URL for accessing stored files (set in R2 bucket settings)
R2_PUBLIC_URL=https://your-custom-domain-or-r2-url.com

# ── SMTP2GO (transactional email) ─────────────────────────────────────────────
SMTP2GO_API_KEY=your_smtp2go_api_key
SMTP_API_URL=https://api.smtp2go.com/v3/email/send
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=HR System

# ── Per-entity SMTP profiles (optional — map to PolicyTemplate.smtpProfile) ──
# Pattern: SMTP2GO_{PROFILE}_USER / _PASS / _FROM_EMAIL / _FROM_NAME
# Example for entity with smtpProfile = "kgi":
# SMTP2GO_KGI_USER=
# SMTP2GO_KGI_PASS=
# SMTP2GO_KGI_FROM_EMAIL=
# SMTP2GO_KGI_FROM_NAME=

# ── Internal HMAC secrets (used by /internal routes) ──────────────────────────
HR_LEGAL_SECRET=change_me
HR_INVENTORY_SECRET=change_me
